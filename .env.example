# Postgres connection string (Neon / Vercel Postgres). Use the POOLED url with sslmode=require.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Strong random string used to sign tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Read/write token from the Vercel Blob store (auto-injected on Vercel).
BLOB_READ_WRITE_TOKEN=YOUR_BLOB_TOKEN_HERE

# Canonical public site URL (no trailing slash), e.g. https://shahwashing.com.
# Leave unset on Vercel to fall back to the auto-injected production URL.
# Set this once you connect a custom domain — it drives canonical URLs,
# hreflang, the sitemap, Open Graph and JSON-LD.
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token (the content of the HTML-tag method,
# i.e. the `content` value of the google-site-verification meta tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
